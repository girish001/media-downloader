// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum OutputFormat {
  MP4_4K
  MP4_1440P
  MP4_1080P
  MP4_720P
  MP4_480P
  MP4_360P
  MP3
}

model DownloadJob {
  id           String       @id @default(uuid())
  url          String
  platform     String
  format       OutputFormat
  status       JobStatus    @default(QUEUED)
  progress     Int          @default(0)
  storageKey   String?
  downloadUrl  String?
  errorMessage String?
  clientIp     String?
  fileSizeBytes BigInt?
  durationSecs  Int?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([clientIp])
}

model ParseEvent {
  id        String   @id @default(uuid())
  url       String
  platform  String
  clientIp  String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique
  permissions String[]  @default(["read"])
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  revoked     Boolean   @default(false)
}

// Analytics event log — every download_queued, download_completed, download_failed, etc.
// Written by services/analytics.ts. Used by admin dashboard for charts.
model DownloadAnalytics {
  id            String   @id @default(uuid())
  event         String                        // e.g. "download_queued", "download_completed"
  jobId         String?
  platform      String?
  format        String?
  clientIp      String?
  userAgent     String?
  errorMessage  String?
  durationMs    Int?
  fileSizeBytes BigInt?
  meta          String?                       // JSON blob for extra context
  createdAt     DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([platform])
  @@index([jobId])
}
