{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "NodeNext",
    "moduleResolution":           "NodeNext",
    "outDir":                     "./dist",
    "rootDir":                    "./src",
    "strict":                     false,
    "esModuleInterop":            true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck":               true,
    "sourceMap":                  true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
