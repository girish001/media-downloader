# ═══════════════════════════════════════════════════════════════════════
#  MediaProc — Environment Variables Reference
#  ─────────────────────────────────────────────
#  For LOCAL development:  copy this to .env  (docker-compose reads it)
#  For RAILWAY deployment: set these in the Railway service Variables tab
#                          (do NOT commit real credentials to git)
# ═══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────
# Railway: set DATABASE_URL in the backend + worker service variables
# Docker:  built from DB_NAME / DB_USER / DB_PASSWORD below
DATABASE_URL=postgresql://mediaproc:devpassword123@localhost:5432/mediaproc
DB_NAME=mediaproc
DB_USER=mediaproc
DB_PASSWORD=devpassword123

# ── Redis ──────────────────────────────────────────────────────────────
# Railway: set REDIS_URL in the backend + worker service variables
REDIS_URL=redis://:devredis123@localhost:6379
REDIS_PASSWORD=devredis123

# ── AWS S3 (REQUIRED — backend + worker) ──────────────────────────────
# Use the AWS_ naming on Railway (standard).
# The S3_ aliases work too (legacy/MinIO docker-compose setups).
# Both sets are accepted; AWS_ takes priority when both are present.

# Railway / AWS production:
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_BUCKET=mediaproc-outputs

# Local MinIO (docker-compose) — alternative naming accepted by the app:
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_BUCKET=mediaproc
# S3_ENDPOINT=http://localhost:9000
# S3_PATH_STYLE=true
# S3_PUBLIC_URL=http://localhost:9000/mediaproc

# MinIO Console: http://localhost:9001  (login: minioadmin / minioadmin)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── File lifecycle ─────────────────────────────────────────────────────
# How long S3 output files are kept before auto-deletion.
# The S3 lifecycle rule is applied automatically on startup.
FILE_TTL_HOURS=24

# ── Size and duration caps ─────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=500
MAX_VIDEO_DURATION_SEC=7200

# ── Worker concurrency ─────────────────────────────────────────────────
# MAX_CONCURRENT_JOBS  — Railway/production name (takes priority)
# WORKER_CONCURRENCY   — legacy docker-compose alias (still supported)
MAX_CONCURRENT_JOBS=2
# WORKER_CONCURRENCY=2

# ── API rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=300          # requests per IP per minute (all routes)
RATE_LIMIT_DOWNLOAD_MAX=60         # downloads per IP per 10 minutes (burst)
RATE_LIMIT_DOWNLOAD_WINDOW=10 minutes
RATE_LIMIT_DAILY_MAX=20            # downloads per IP per calendar day (Redis-backed)

# ── Job processing ─────────────────────────────────────────────────────
JOB_TIMEOUT_SEC=600
YTDLP_TIMEOUT_SEC=300
SIGNED_URL_TTL_SEC=3600

# ── CORS (backend) ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=debug        # debug | info | warn | error
NODE_ENV=development   # development | production

# ── Optional: Sentry error tracking ───────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Optional: platform auth (needed for private/restricted content) ────
# IG_SESSION_ID=your_instagram_session_id
# FB_COOKIES_FILE=/run/secrets/fb_cookies.txt

# ── Optional: Captcha (Cloudflare Turnstile) ──────────────────────────
# CAPTCHA_SECRET_KEY=your_turnstile_secret_key

# ── Frontend ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
